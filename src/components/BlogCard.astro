---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  excerpt: string;
  date: Date;
  href: string;
  coverImage?: ImageMetadata;
  class?: string;
}

const { title, excerpt, date, href, coverImage, class: className = "" } = Astro.props;

const formattedDate = date.toLocaleDateString("en-IN", { day: "numeric", month: "long", year: "numeric" });
---

<a
  href={href}
  class:list={[
    "group block overflow-hidden rounded-[22px] bg-white transition-transform duration-150 ease-out hover:-translate-y-0.5 md:rounded-[24px]",
    className,
  ]}
>
  {
    coverImage ? (
      <Image src={coverImage} alt="" width={400} height={220} class="h-[160px] w-full object-cover md:h-[180px]" />
    ) : (
      <div class="flex h-[90px] items-end px-5 pt-5 md:h-[100px] md:px-6 md:pt-6">
        <div class="h-9 w-9 rounded-[52%_48%_47%_53%/50%_52%_48%_50%] bg-clay-100" />
      </div>
    )
  }
  <div class:list={coverImage ? "p-5 md:p-6" : "px-5 pb-5 md:px-6 md:pb-6"}>
    <div class="text-xs text-ink-muted md:text-[13px]">{formattedDate}</div>
    <div class="mt-1.5 font-display text-[16px] font-bold text-ink md:text-[17px]">{title}</div>
    <p class="mt-2 text-[13.5px] leading-[1.55] text-ink-soft md:text-[14px]">{excerpt}</p>
  </div>
</a>
