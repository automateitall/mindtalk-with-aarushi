---
// Renders one testimonial. Display name resolution (full/first/initials/
// anonymous) happens where the data is authored — see src/pages/index.astro
// for the placeholder set and Build Spec §5 for the Tina schema this will
// eventually read from.
interface Props {
  quote: string;
  attribution: string;
  class?: string;
}

const { quote, attribution, class: className = "" } = Astro.props;
---

<div class:list={["rounded-[22px] bg-white p-[22px]", className]}>
  <p class="m-0 text-base leading-[1.55] text-[#5a4c40]">&ldquo;{quote}&rdquo;</p>
  <div class="mt-3 text-xs text-ink-faint">{attribution}</div>
</div>
