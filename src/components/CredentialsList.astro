---
interface CredentialItem {
  label: string;
  note?: string;
  pending?: boolean;
}

interface Props {
  items: readonly CredentialItem[];
  class?: string;
}

const { items, class: className = "" } = Astro.props;
---

<div
  class:list={[
    "divide-y divide-[rgba(59,47,40,0.08)] overflow-hidden rounded-[22px] bg-white md:rounded-[24px]",
    className,
  ]}
>
  {
    items.map((item) => (
      <div class:list={["flex items-start gap-3 px-5 py-4 md:px-6 md:py-[18px]", item.pending && "bg-cream-alt/50"]}>
        <span
          class="mt-1.5 h-2 w-2 flex-none rounded-full"
          style={{ background: item.pending ? "var(--color-clay-300)" : "var(--color-sage)" }}
        />
        <div>
          <div class="font-display text-[15px] font-semibold text-ink md:text-base">{item.label}</div>
          {item.note && (
            <div class="mt-0.5 text-[12.5px] italic leading-[1.4] text-ink-muted md:text-[13px]">{item.note}</div>
          )}
        </div>
      </div>
    ))
  }
</div>
