---
interface Props {
  title: string;
  description: string;
  color: string;
  radius?: string;
  class?: string;
}

const { title, description, color, radius = "50% 50% 46% 54%", class: className = "" } = Astro.props;
---

<div class:list={["rounded-[22px] bg-white p-[18px] md:rounded-[24px] md:p-6 lg:p-[26px]", className]}>
  <div
    class="mb-3 h-8 w-8 md:mb-3.5 md:h-[38px] md:w-[38px] lg:mb-4 lg:h-10 lg:w-10"
    style={{ background: color, borderRadius: radius }}
  />
  <div class="font-display text-[15px] font-semibold text-ink md:text-[17px] lg:text-[18px]">{title}</div>
  <div class="mt-[3px] text-[12.5px] leading-[1.4] text-ink-muted md:mt-[5px] md:text-sm md:leading-[1.5]">
    {description}
  </div>
</div>
