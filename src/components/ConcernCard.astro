---
interface Props {
  title: string;
  description: string;
  color: string;
  radius?: string;
  wide?: boolean;
  class?: string;
}

const {
  title,
  description,
  color,
  radius = "50% 50% 46% 54%",
  wide = false,
  class: className = "",
} = Astro.props;
---

{
  wide ? (
    <div class:list={["flex w-full items-center gap-3.5 rounded-[22px] bg-white p-[18px]", className]}>
      <div class="h-8 w-8 flex-none" style={{ background: color, borderRadius: radius }} />
      <div>
        <div class="font-display text-[15px] font-semibold text-ink">{title}</div>
        <div class="mt-[3px] text-[12.5px] leading-[1.4] text-ink-muted">{description}</div>
      </div>
    </div>
  ) : (
    <div class:list={["flex-1 basis-[45%] rounded-[22px] bg-white p-[18px]", className]}>
      <div class="mb-3 h-8 w-8" style={{ background: color, borderRadius: radius }} />
      <div class="font-display text-[15px] font-semibold text-ink">{title}</div>
      <div class="mt-[3px] text-[12.5px] leading-[1.4] text-ink-muted">{description}</div>
    </div>
  )
}
