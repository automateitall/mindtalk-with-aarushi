---
interface Props {
  label: string;
  price: string;
  note: string;
  class?: string;
}

const { label, price, note, class: className = "" } = Astro.props;
---

<div class:list={["flex-1 rounded-[22px] bg-white px-5 py-[22px]", className]}>
  <div class="font-display text-[15px] font-bold text-ink">{label}</div>
  <div class="my-2 font-display text-[26px] font-extrabold text-terracotta">{price}</div>
  <div class="text-xs leading-[1.4] text-ink-muted">{note}</div>
</div>
