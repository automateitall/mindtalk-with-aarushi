---
interface Props {
  href: string;
  variant?: "primary" | "secondary" | "text";
  size?: "md" | "lg";
  full?: boolean;
  dot?: boolean;
  class?: string;
}

const {
  href,
  variant = "primary",
  size = "md",
  full = false,
  dot = false,
  class: className = "",
} = Astro.props;

const base =
  "inline-flex items-center justify-center gap-2 font-display font-bold transition-transform duration-150 ease-out active:scale-[0.97]";

const variants = {
  primary:
    "rounded-full bg-terracotta text-white shadow-[0_12px_26px_-10px_rgba(192,118,90,0.85)]",
  secondary: "rounded-full bg-white text-ink-soft shadow-[0_8px_20px_-10px_rgba(60,40,30,0.4)]",
  text: "text-ink",
};

const sizes = {
  md: "h-10 px-[18px] text-sm",
  lg: "h-14 px-[34px] text-[16px]",
};

const sizeClass = variant === "text" ? "" : sizes[size];
---

<a href={href} class:list={[base, variants[variant], sizeClass, full && "flex-1", className]}>
  {dot && <span class="h-2 w-2 rounded-full bg-terracotta-light"></span>}
  <slot />
</a>
