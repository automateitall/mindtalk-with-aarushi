---
import { site, waLink, telLink } from "../config/site";
import CrisisNote from "./CrisisNote.astro";
---

<footer class="bg-ink text-footer-text">
  <div class="wrap pb-8 pt-[26px] md:py-10 lg:py-11">
    <CrisisNote class="md:max-w-[640px] lg:max-w-[720px]" />

    <div class="my-6 h-px bg-white/10 md:my-7 lg:my-8"></div>

    <div class="flex flex-wrap items-end justify-between gap-5">
      <div>
        <div class="font-display text-[19px] font-extrabold text-cream-deep md:text-xl lg:text-[22px]">
          MindTalk<span class="text-terracotta">.</span>
          <span class="ml-1 text-sm font-medium text-ink-faint-2 lg:text-[15px]">with Aarushi</span>
        </div>
        <div class="mt-2 text-[13px] leading-[1.6] text-ink-faint-2 md:text-[13.5px] lg:text-sm">
          {site.address.short} &middot; In-person &amp; online
        </div>
      </div>
      <div class="flex gap-4 text-[13px] text-[#c9b6a4] md:gap-6 md:text-sm lg:gap-[26px]">
        <a href={waLink()}>WhatsApp</a>
        <a href={telLink()}>Call</a>
        <a href={`mailto:${site.email}`}>Email</a>
      </div>
    </div>

    <div class="mt-6 flex flex-wrap gap-x-4 gap-y-1.5 text-xs text-ink-faint-2 md:mt-7 md:text-[12.5px]">
      <a href="/faq">FAQ</a>
      <a href="/online-therapy">Online Therapy</a>
      <a href="/privacy-policy">Privacy Policy</a>
    </div>
  </div>
</footer>
