---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import StickyCtaBar from "../components/StickyCtaBar.astro";
import StructuredData from "../components/StructuredData.astro";
import { site } from "../config/site";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f4eae1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={Astro.url} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <StructuredData />
  </head>
  <body class="m-0">
    <div
      class="relative mx-auto min-h-screen max-w-[480px] overflow-hidden bg-cream pb-24 shadow-none md:max-w-[834px] md:pb-0 md:shadow-[0_30px_80px_-30px_rgba(60,40,30,0.4)] lg:max-w-none lg:overflow-visible lg:shadow-none"
    >
      <Nav />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
    <StickyCtaBar />
  </body>
</html>
