---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Section from "../components/Section.astro";
import ClosingCta from "../components/ClosingCta.astro";
import { faq } from "../config/faq";
import { genericCrisisNote } from "../config/site";
---

<Layout title={faq.seoTitle} description={faq.seoDescription}>
  <!-- ===== HERO ===== -->
  <div class="relative overflow-hidden">
    <div class="absolute -right-[70px] -top-20 h-[220px] w-[220px] rounded-[58%_42%_47%_53%/55%_44%_56%_45%] bg-sage-100 md:-top-24 md:h-[280px] md:w-[280px] lg:-right-16 lg:-top-28 lg:h-[340px] lg:w-[340px]">
    </div>
    <div class="absolute -left-14 top-[170px] h-[110px] w-[110px] rounded-[50%_50%_45%_55%/55%_50%_50%_45%] bg-sage-50 md:top-auto md:-bottom-8 md:-left-[50px] md:h-[140px] md:w-[140px] lg:-left-16 lg:-bottom-5 lg:h-[170px] lg:w-[170px]">
    </div>

    <Header />

    <div class="wrap relative pb-8 pt-[22px] md:pb-10 md:pt-10 md:text-center lg:pb-12 lg:pt-12">
      <div class="mb-2.5 font-display text-sm font-semibold tracking-[0.01em] text-terracotta md:mx-auto md:mb-3 md:text-[15px] lg:mb-3.5 lg:text-base">
        {faq.eyebrow}
      </div>
      <h1 class="m-0 text-balance font-display text-[30px] font-bold leading-[1.14] tracking-[-0.02em] text-ink md:mx-auto md:max-w-[580px] md:text-[38px] md:leading-[1.1] lg:max-w-[680px] lg:text-[44px] lg:leading-[1.08]">
        {faq.headline}
      </h1>
      <p class="mt-3 text-[15.5px] leading-[1.55] text-ink-soft md:mx-auto md:mt-4 md:max-w-[540px] md:text-[16.5px] lg:max-w-[600px] lg:text-[17.5px]">
        {faq.lead}
      </p>
    </div>
  </div>

  <!-- ===== ACCORDION — native <details>/<summary>, no JS required ===== -->
  <Section innerClass="wrap pb-8 pt-2 md:pb-10 lg:pb-12">
    <div class="mx-auto flex max-w-[720px] flex-col gap-2.5 md:gap-3">
      {
        faq.items.map((item) => (
          <details class="group rounded-[18px] bg-white px-5 py-1 md:rounded-[20px] md:px-6">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-4 font-display text-[15.5px] font-semibold text-ink marker:content-[''] [&::-webkit-details-marker]:hidden md:py-[18px] md:text-base">
              {item.question}
              <span class="flex-none text-lg leading-none text-terracotta transition-transform duration-150 group-open:rotate-45">
                +
              </span>
            </summary>
            <p class="m-0 pb-4 text-[14.5px] leading-[1.65] text-ink-soft md:pb-5 md:text-[15px]">
              {item.answer.map((seg) =>
                seg.href ? (
                  <a
                    href={seg.href}
                    class="font-semibold text-terracotta underline decoration-[rgba(192,118,90,0.35)] underline-offset-[3px]"
                  >
                    {seg.text}
                  </a>
                ) : (
                  seg.text
                ),
              )}
            </p>
          </details>
        ))
      }
    </div>
  </Section>

  <!-- ===== SOFT CTA ===== -->
  <ClosingCta heading={faq.cta.heading} subhead={faq.cta.subhead} />

  <!-- ===== SMALL FOOT-OF-PAGE CRISIS NOTE ===== -->
  <div class="wrap pb-6 text-center md:pb-8">
    <p class="m-0 text-xs leading-[1.6] text-ink-muted md:text-[13px]">{genericCrisisNote}</p>
  </div>
</Layout>
