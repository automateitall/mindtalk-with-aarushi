---
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import ConcernCard from "../../components/ConcernCard.astro";
import Section from "../../components/Section.astro";
import ClosingCta from "../../components/ClosingCta.astro";
import { services, type ServiceContent } from "../../config/services";
import { site } from "../../config/site";
import heroPhoto from "../../assets/images/aarushi-hero.webp";

export function getStaticPaths() {
  return Object.entries(services).map(([slug, content]) => ({
    params: { slug },
    props: { content },
  }));
}

interface Props {
  content: ServiceContent;
}

const { content } = Astro.props;

// Section headings: left-aligned on mobile, centered with a measured
// max-width from tablet up — same treatment as Home/About.
const heading = "md:mx-auto md:max-w-[560px] md:text-center lg:max-w-[640px]";
---

<Layout title={content.seoTitle} description={content.seoDescription}>
  <!-- ===== HERO — no photo; soft organic shapes instead of a clinical image =====
       Blob lean varies per page (content.heroAccent): "balanced" (Hypnotherapy),
       "warm"/clay-terracotta (Expressive Arts), "calm"/restrained-sage (Counselling). -->
  <div class="relative overflow-hidden">
    {
      content.heroAccent === "warm" ? (
        <>
          <div class="absolute -right-[80px] -top-24 h-[270px] w-[270px] rounded-[55%_45%_48%_52%/50%_55%_45%_50%] bg-clay-200 md:-top-28 md:h-[350px] md:w-[350px] lg:-right-20 lg:-top-32 lg:h-[430px] lg:w-[430px]" />
          <div class="absolute -left-16 top-[150px] h-[150px] w-[150px] rounded-[48%_52%_45%_55%/55%_48%_52%_45%] bg-clay-300 md:top-auto md:-bottom-10 md:-left-[60px] md:h-[190px] md:w-[190px] lg:-left-20 lg:-bottom-[30px] lg:h-[230px] lg:w-[230px]" />
          <div class="absolute right-[50px] top-[260px] hidden h-[70px] w-[70px] rounded-[50%_50%_46%_54%] bg-terracotta-light md:block lg:right-[110px] lg:top-[300px] lg:h-[90px] lg:w-[90px]" />
          <div class="absolute right-[180px] top-[60px] hidden h-[36px] w-[36px] rounded-[52%_48%_50%_50%] bg-sage-50 lg:block" />
        </>
      ) : content.heroAccent === "calm" ? (
        <>
          <div class="absolute -right-[70px] -top-20 h-[220px] w-[220px] rounded-[58%_42%_47%_53%/55%_44%_56%_45%] bg-sage-100 md:-top-24 md:h-[280px] md:w-[280px] lg:-right-16 lg:-top-28 lg:h-[340px] lg:w-[340px]" />
          <div class="absolute -left-14 top-[170px] h-[110px] w-[110px] rounded-[50%_50%_45%_55%/55%_50%_50%_45%] bg-sage-50 md:top-auto md:-bottom-8 md:-left-[50px] md:h-[140px] md:w-[140px] lg:-left-16 lg:-bottom-5 lg:h-[170px] lg:w-[170px]" />
        </>
      ) : (
        <>
          <div class="absolute -right-[80px] -top-24 h-[260px] w-[260px] rounded-[58%_42%_47%_53%/55%_44%_56%_45%] bg-sage-50 md:-top-28 md:h-[340px] md:w-[340px] lg:-right-20 lg:-top-32 lg:h-[420px] lg:w-[420px]" />
          <div class="absolute -left-16 top-[160px] h-[140px] w-[140px] rounded-[50%_50%_45%_55%/55%_50%_50%_45%] bg-clay-100 md:top-auto md:-bottom-10 md:-left-[60px] md:h-[180px] md:w-[180px] lg:-left-20 lg:-bottom-[30px] lg:h-[220px] lg:w-[220px]" />
          <div class="absolute right-[60px] top-[280px] hidden h-[90px] w-[90px] rounded-[52%_48%_50%_50%] bg-clay-200 md:block lg:right-[120px] lg:top-[320px] lg:h-[110px] lg:w-[110px]" />
        </>
      )
    }

    <Header />

    <div class="wrap relative pb-12 pt-[22px] md:pb-16 md:pt-14 md:text-center lg:pb-20 lg:pt-20">
      <div class="mb-2.5 font-display text-sm font-semibold tracking-[0.01em] text-terracotta md:mx-auto md:mb-3.5 md:text-[15px] lg:mb-4 lg:text-base">
        {content.eyebrow}
      </div>
      <h1 class="m-0 text-balance font-display text-[32px] font-bold leading-[1.12] tracking-[-0.02em] text-ink md:mx-auto md:max-w-[600px] md:text-[42px] md:leading-[1.08] lg:max-w-[720px] lg:text-[54px] lg:leading-[1.06]">
        {content.headline}
      </h1>
      <p class="mt-4 text-[16.5px] leading-[1.6] text-ink-soft md:mx-auto md:mt-5 md:max-w-[560px] md:text-[18px] lg:max-w-[640px] lg:mt-6 lg:text-[19px]">
        {content.lead}
      </p>
    </div>
  </div>

  <!-- ===== WHAT IT REALLY IS ===== -->
  <Section innerClass="wrap pb-2 pt-11 md:pb-4 md:pt-16 lg:pt-20">
    <div class="md:mx-auto md:max-w-[680px]">
      <div class="font-display text-[24px] font-bold text-ink md:text-[28px] lg:text-[32px]">
        {content.whatItIs.heading}
      </div>
      <p class="mt-4 text-[16px] leading-[1.7] text-ink-soft md:text-[17px] lg:text-[18px]">
        {content.whatItIs.intro}
      </p>

      {
        content.whatItIs.myths && content.whatItIs.myths.length > 0 && (
          <div class="mt-6 rounded-[22px] bg-white p-5 md:mt-8 md:rounded-[24px] md:p-7">
            <p class="m-0 text-[13.5px] font-semibold uppercase tracking-[0.02em] text-ink-softer md:text-sm">
              {content.whatItIs.mythsIntro}
            </p>
            <ul class="m-0 mt-4 flex list-none flex-col gap-3 p-0">
              {content.whatItIs.myths.map((myth) => (
                <li class="flex items-start gap-3">
                  <span class="mt-[7px] h-[7px] w-[7px] flex-none rounded-full bg-sage" />
                  <span class="text-[15px] leading-[1.6] text-ink-soft md:text-base">
                    {myth.pre}
                    <strong class="font-display font-bold text-ink">{myth.strong}</strong>
                    {myth.post}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        )
      }

      {
        content.whatItIs.notes && content.whatItIs.notes.length > 0 && (
          <div class="mt-6 md:mt-8">
            <p class="m-0 text-[15px] font-semibold text-ink-softer md:text-base">{content.whatItIs.notesIntro}</p>
            <ul class="m-0 mt-3 flex list-none flex-col gap-2.5 p-0">
              {content.whatItIs.notes.map((note) => (
                <li class="flex items-start gap-2.5">
                  <span class="mt-2 h-[5px] w-[5px] flex-none rounded-full bg-ink-muted" />
                  <span class="text-[15px] leading-[1.65] text-ink-soft md:text-base">{note}</span>
                </li>
              ))}
            </ul>
          </div>
        )
      }

      <p class="mt-6 text-[16px] leading-[1.7] text-ink-soft md:text-[17px] lg:text-[18px]">
        {content.whatItIs.closing}
      </p>
    </div>
  </Section>

  <!-- ===== WHO IT CAN HELP ===== -->
  <Section background="alt" class="mt-[38px] md:mt-16 lg:mt-20" innerClass="wrap py-10 md:py-14 lg:py-[72px]">
    <div class={heading}>
      <div class="font-display text-[26px] font-bold leading-[1.15] text-ink md:text-[32px] md:leading-[1.12] lg:text-[38px]">
        {content.whoItHelps.heading}
      </div>
      <p class="mb-[22px] mt-2 text-[15px] leading-[1.55] text-ink-soft md:mb-9 md:mt-3 md:text-base lg:mb-10 lg:text-[17px]">
        {content.whoItHelps.intro}
      </p>
    </div>
    <div class="grid grid-cols-2 gap-[11px] md:gap-4 lg:grid-cols-3 lg:gap-[18px]">
      {content.whoItHelps.items.map((item) => <ConcernCard {...item} />)}
      {
        content.whoItHelps.catchAll && (
          <div class="flex flex-col justify-center rounded-[22px] border-2 border-dashed border-[rgba(192,118,90,0.25)] bg-white/60 p-[18px] md:rounded-[24px] md:p-6 lg:p-[26px]">
            <div class="font-display text-[15px] font-semibold leading-[1.3] text-ink md:text-base lg:text-[17px]">
              {content.whoItHelps.catchAll.title}
            </div>
            <div class="mt-1.5 text-[12.5px] leading-[1.4] text-ink-muted md:text-sm md:leading-[1.5]">
              {content.whoItHelps.catchAll.description}
            </div>
          </div>
        )
      }
    </div>
    <p class="mx-auto mt-6 max-w-[640px] text-[14.5px] leading-[1.6] text-ink-soft md:mt-8 md:text-center md:text-[15px] lg:mt-9">
      {content.whoItHelps.closing}
    </p>
    <p class="mx-auto mt-3 max-w-[640px] text-[13px] italic leading-[1.55] text-ink-muted md:text-center">
      {content.whoItHelps.crisisCaveat}
    </p>
  </Section>

  <!-- ===== HOW IT HELPS ===== -->
  <Section innerClass="wrap pb-2 pt-11 md:pb-4 md:pt-16 lg:pt-20">
    <div class="md:mx-auto md:max-w-[680px]">
      <div class="font-display text-[24px] font-bold text-ink md:text-[28px] lg:text-[32px]">
        {content.howItHelps.heading}
      </div>
      <p class="mt-4 text-[16px] leading-[1.7] text-ink-soft md:text-[17px] lg:text-[18px]">
        {content.howItHelps.intro}
      </p>
      <ul class="m-0 mt-4 flex list-none flex-col gap-3 p-0">
        {
          content.howItHelps.points.map((point) => (
            <li class="flex items-start gap-3">
              <span class="mt-[7px] h-[7px] w-[7px] flex-none rounded-full bg-terracotta-light" />
              <span class="text-[15px] leading-[1.6] text-ink-soft md:text-base">{point}</span>
            </li>
          ))
        }
      </ul>
      <p class="mt-5 text-[16px] leading-[1.7] text-ink-soft md:text-[17px] lg:text-[18px]">
        {content.howItHelps.closing}
      </p>
    </div>
  </Section>

  <!-- ===== WORKING WITH ME ===== -->
  <Section background="alt" class="mt-[38px] md:mt-16 lg:mt-20" innerClass="wrap py-10 md:grid md:grid-cols-[auto_1fr] md:items-start md:gap-8 md:py-14 lg:gap-10 lg:py-[72px]">
    <div class="flex justify-center md:block">
      <div class="h-20 w-20 flex-none overflow-hidden rounded-[52%_48%_47%_53%/50%_52%_48%_50%] bg-clay-200 md:h-24 md:w-24 lg:h-28 lg:w-28">
        <Image
          src={heroPhoto}
          alt={site.practitioner}
          width={112}
          height={112}
          class="h-full w-full object-cover"
        />
      </div>
    </div>
    <div class="mt-5 md:mt-0 md:max-w-[600px]">
      <div class="font-display text-[24px] font-bold text-ink md:text-[28px] lg:text-[32px]">
        {content.workingWithMe.heading}
      </div>
      {
        content.workingWithMe.paragraphs.map((segments) => (
          <p class="mt-3 text-[16px] leading-[1.7] text-ink-soft md:text-[17px] lg:text-[18px]">
            {segments.map((seg) =>
              seg.href ? (
                <a
                  href={seg.href}
                  class="font-semibold text-terracotta underline decoration-[rgba(192,118,90,0.35)] underline-offset-[3px]"
                >
                  {seg.text}
                </a>
              ) : seg.emphasis === "pending" ? (
                <span class="text-[0.85em] italic text-ink-muted"> ({seg.text})</span>
              ) : (
                seg.text
              ),
            )}
          </p>
        ))
      }
    </div>
  </Section>

  <!-- ===== SOFT CTA ===== -->
  <ClosingCta heading={content.cta.heading} subhead={content.cta.subhead} />

  <!-- ===== SMALL FOOT-OF-PAGE CRISIS NOTE ===== -->
  <div class="wrap pb-6 text-center md:pb-8">
    <p class="m-0 text-xs leading-[1.6] text-ink-muted md:text-[13px]">{content.footCrisisNote}</p>
  </div>
</Layout>
