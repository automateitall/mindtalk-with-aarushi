---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Section from "../../components/Section.astro";
import ClosingCta from "../../components/ClosingCta.astro";
import { servicesHub } from "../../config/services";
---

<Layout title={servicesHub.seoTitle} description={servicesHub.seoDescription}>
  <!-- ===== HERO — tighter than Home's; this is a signpost page, not a landing hero ===== -->
  <div class="relative overflow-hidden">
    <div class="absolute -right-[80px] -top-24 h-[230px] w-[230px] rounded-[58%_42%_47%_53%/55%_44%_56%_45%] bg-sage-50 md:-top-24 md:h-[290px] md:w-[290px] lg:-right-20 lg:-top-28 lg:h-[360px] lg:w-[360px]">
    </div>
    <div class="absolute -left-16 top-[150px] h-[120px] w-[120px] rounded-[50%_50%_45%_55%/55%_50%_50%_45%] bg-clay-100 md:top-auto md:-bottom-8 md:-left-[50px] md:h-[150px] md:w-[150px] lg:-left-16 lg:-bottom-5 lg:h-[180px] lg:w-[180px]">
    </div>

    <Header />

    <div class="wrap relative pb-8 pt-[22px] md:pb-10 md:pt-10 md:text-center lg:pb-12 lg:pt-12">
      <div class="mb-2.5 font-display text-sm font-semibold tracking-[0.01em] text-terracotta md:mx-auto md:mb-3 md:text-[15px] lg:mb-3.5 lg:text-base">
        {servicesHub.eyebrow}
      </div>
      <h1 class="m-0 text-balance font-display text-[30px] font-bold leading-[1.14] tracking-[-0.02em] text-ink md:mx-auto md:max-w-[580px] md:text-[38px] md:leading-[1.1] lg:max-w-[720px] lg:text-[46px] lg:leading-[1.08]">
        {servicesHub.headline}
      </h1>
      <p class="mt-3 text-[15.5px] leading-[1.55] text-ink-soft md:mx-auto md:mt-4 md:max-w-[540px] md:text-[16.5px] lg:max-w-[600px] lg:text-[17.5px]">
        {servicesHub.lead}
      </p>
    </div>
  </div>

  <!-- ===== SERVICE CARDS + compressed blend band ===== -->
  <Section innerClass="wrap pb-8 pt-2 md:pb-10 lg:pb-12">
    <div class="grid grid-cols-1 gap-3.5 md:grid-cols-3 md:gap-4 lg:gap-5">
      {
        servicesHub.cards.map((card) => (
          <a
            href={`/services/${card.slug}`}
            class="group block rounded-[22px] bg-white p-6 transition-transform duration-150 ease-out hover:-translate-y-0.5 md:rounded-[24px] md:p-7"
          >
            <div
              class="h-10 w-10 rounded-[52%_48%_47%_53%/50%_52%_48%_50%] md:h-11 md:w-11"
              style={{ background: card.color }}
            />
            <div class="mt-4 font-display text-[19px] font-bold text-ink md:text-[20px]">{card.title}</div>
            <p class="mt-2 text-[14.5px] leading-[1.6] text-ink-soft md:text-[15px]">{card.description}</p>
            <span class="mt-4 inline-flex items-center gap-1.5 font-display text-sm font-semibold text-terracotta">
              Learn more
              <span aria-hidden="true" class="transition-transform duration-150 ease-out group-hover:translate-x-0.5">
                &rarr;
              </span>
            </span>
          </a>
        ))
      }
    </div>

    <!-- Compressed 2-line band, not a full section — format/fees live on the Fees page. -->
    <p class="mx-auto mt-6 max-w-[640px] text-center text-[14.5px] leading-[1.6] text-ink-soft md:mt-7 md:text-[15px] lg:mt-8">
      {servicesHub.blendNote}
    </p>
  </Section>

  <!-- ===== SOFT CTA ===== -->
  <ClosingCta heading={servicesHub.cta.heading} subhead={servicesHub.cta.subhead} />

  <!-- ===== SMALL FOOT-OF-PAGE CRISIS NOTE ===== -->
  <div class="wrap pb-6 text-center md:pb-8">
    <p class="m-0 text-xs leading-[1.6] text-ink-muted md:text-[13px]">{servicesHub.footCrisisNote}</p>
  </div>
</Layout>
