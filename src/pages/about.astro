---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import TrustStrip from "../components/TrustStrip.astro";
import ConcernCard from "../components/ConcernCard.astro";
import Section from "../components/Section.astro";
import CredentialsList from "../components/CredentialsList.astro";
import ClosingCta from "../components/ClosingCta.astro";
import { site } from "../config/site";
import heroPhoto from "../assets/images/aarushi-hero.webp";

const { about } = site;

// Section headings: left-aligned on mobile, centered with a measured
// max-width from tablet up — same treatment as the homepage.
const heading = "md:mx-auto md:max-w-[560px] md:text-center lg:max-w-[640px]";
---

<Layout title={about.seoTitle} description={about.seoDescription}>
  <!-- ===== HERO ===== -->
  <div class="relative overflow-hidden">
    <div
      class="absolute -right-[60px] -top-20 h-[240px] w-[240px] rounded-[55%_45%_50%_50%/50%_55%_45%_50%] bg-sage-50 md:-top-[110px] md:h-[320px] md:w-[320px] lg:-right-16 lg:-top-[130px] lg:h-[400px] lg:w-[400px]"
    >
    </div>
    <div
      class="absolute -left-16 top-[140px] h-[130px] w-[130px] rounded-[50%_50%_45%_55%/55%_50%_50%_45%] bg-clay-100 md:top-auto md:-bottom-[40px] md:-left-[60px] md:h-[170px] md:w-[170px] lg:-left-[80px] lg:-bottom-[50px] lg:h-[200px] lg:w-[200px]"
    >
    </div>

    <Header />

    <div
      class="wrap relative md:grid md:grid-cols-[1.05fr_.95fr] md:items-center md:gap-10 md:pb-[56px] md:pt-14 lg:grid-cols-[1fr_1fr] lg:gap-14 lg:pb-[76px] lg:pt-[72px]"
    >
      <div class="pt-[22px] md:pt-0">
        <div class="mb-2.5 font-display text-sm font-semibold tracking-[0.01em] text-terracotta md:mb-[14px] md:text-[15px] lg:mb-4 lg:text-base">
          {about.eyebrow}
        </div>
        <h1 class="m-0 text-balance font-display text-[32px] font-bold leading-[1.12] tracking-[-0.02em] text-ink md:text-[42px] md:leading-[1.08] lg:text-[54px] lg:leading-[1.06]">
          {about.headline}
        </h1>
        <p class="mt-4 text-[16.5px] leading-[1.6] text-ink-soft md:mt-5 md:max-w-[440px] md:text-[18px] lg:mt-6 lg:max-w-[480px] lg:text-[19px]">
          {about.lead}
        </p>

        <TrustStrip items={[...site.roleBadges]} align="start" class="mt-6 hidden md:flex" />
      </div>

      <div class="relative flex justify-center pt-6 md:pt-0">
        <div class="relative">
          <div
            class="h-[300px] w-[300px] overflow-hidden rounded-[50%_50%_48%_52%/48%_52%_50%_50%] bg-clay-200 shadow-[0_24px_50px_-22px_rgba(120,70,50,0.55)] md:h-[340px] md:shadow-[0_28px_60px_-26px_rgba(120,70,50,0.55)] lg:h-[440px] lg:w-[400px] lg:shadow-[0_34px_70px_-28px_rgba(120,70,50,0.6)]"
          >
            <Image
              src={heroPhoto}
              alt={`${site.practitioner}, relaxed and smiling`}
              width={400}
              height={440}
              class="h-full w-full object-cover"
            />
          </div>
          <div class="absolute bottom-1 left-[26px] h-[42px] w-[42px] rounded-[50%_50%_46%_54%/55%_46%_54%_45%] bg-sage md:bottom-[12px] md:left-[18px] md:h-[52px] md:w-[52px] lg:left-[24px] lg:h-[62px] lg:w-[62px]">
          </div>
        </div>
      </div>
    </div>

    <!-- mobile+tablet: badges below the photo (desktop moves them into the text column above) -->
    <div class="wrap relative pt-[22px] md:hidden">
      <TrustStrip items={[...site.roleBadges]} />
    </div>
  </div>

  <!-- ===== MY APPROACH ===== -->
  <Section innerClass="wrap pb-2 pt-11 md:pb-4 md:pt-16 lg:pt-20">
    <div class="md:mx-auto md:max-w-[640px]">
      <div class="font-display text-[24px] font-bold text-ink md:text-[28px] lg:text-[32px]">
        My approach
      </div>
      <div class="mt-4 flex flex-col gap-4 md:mt-6 md:gap-5">
        {
          about.approach.map((paragraph) => (
            <p class="m-0 text-[16px] leading-[1.7] text-ink-soft md:text-[17px] lg:text-[18px]">{paragraph}</p>
          ))
        }
      </div>
    </div>
  </Section>

  <!-- ===== HOW I WORK — THREE THREADS ===== -->
  <Section id="threads" background="alt" class="mt-[38px] md:mt-16 lg:mt-20" innerClass="wrap py-10 md:py-14 lg:py-[72px]">
    <div class={heading}>
      <div class="font-display text-[26px] font-bold leading-[1.15] text-ink md:text-[32px] md:leading-[1.12] lg:text-[38px]">
        How I work — three threads
      </div>
      <p class="mb-[22px] mt-2 text-[15px] leading-[1.55] text-ink-soft md:mb-9 md:mt-3 md:text-base lg:mb-10 lg:text-[17px]">
        {about.modalitiesIntro}
      </p>
    </div>
    <div class="grid grid-cols-1 gap-3 md:grid-cols-3 md:gap-4 lg:gap-[18px]">
      {about.modalities.map((m) => <ConcernCard {...m} />)}
    </div>
    <p class="mx-auto mt-6 max-w-[640px] text-[14.5px] leading-[1.6] text-ink-muted md:mt-8 md:text-center md:text-[15px] lg:mt-9">
      {about.modalitiesOutro}
    </p>
  </Section>

  <!-- ===== CREDENTIALS ===== -->
  <Section innerClass="wrap pb-2 pt-11 md:pb-4 md:pt-16 lg:pt-20">
    <div class="md:mx-auto md:max-w-[640px]">
      <div class="mb-[18px] font-display text-[24px] font-bold text-ink md:mb-6 md:text-[28px] lg:text-[32px]">
        Credentials
      </div>
      <CredentialsList items={about.credentials} />
    </div>
  </Section>

  <!-- ===== WHERE & HOW ===== -->
  <Section
    background="alt"
    class="relative mt-[38px] overflow-hidden md:mt-16 lg:mt-20"
    innerClass="wrap py-10 md:py-14 lg:py-[72px]"
  >
    <div slot="decor">
      <div
        class="absolute -right-[50px] -top-[40px] h-[130px] w-[130px] rounded-[55%_45%_50%_50%] bg-clay-300 md:-top-[50px] md:-right-[60px] md:h-[160px] md:w-[160px] lg:h-[190px] lg:w-[190px]"
      >
      </div>
    </div>
    <div class="md:mx-auto md:max-w-[640px] md:text-center">
      <div class="font-display text-[24px] font-bold text-ink md:text-[28px] lg:text-[32px]">Where &amp; how</div>
      <p class="mt-3 text-[16px] leading-[1.65] text-[#5a4c40] md:mt-4 md:text-[17px] lg:text-[18px]">
        {about.whereHow}
      </p>
    </div>
  </Section>

  <!-- ===== CLOSING CTA ===== -->
  <ClosingCta subhead={about.closingSubhead} />
</Layout>
