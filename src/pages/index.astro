---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import TrustStrip from "../components/TrustStrip.astro";
import AvailabilityBadge from "../components/AvailabilityBadge.astro";
import ConcernCard from "../components/ConcernCard.astro";
import Section from "../components/Section.astro";
import StepItem from "../components/StepItem.astro";
import FeeCard from "../components/FeeCard.astro";
import TestimonialCard from "../components/TestimonialCard.astro";
import WhatsAppCTA from "../components/WhatsAppCTA.astro";
import CallCTA from "../components/CallCTA.astro";
import ClosingCta from "../components/ClosingCta.astro";
import { site } from "../config/site";
import heroPhoto from "../assets/images/aarushi-hero.webp";
import aboutPhoto from "../assets/images/aarushi-about.webp";

const title = `${site.name} — Therapy for anxiety, stress & relationships in Gole Market, Delhi & online`;
const description =
  "Gentle, professional therapy with Aarushi Sabharwal — Counselling Psychologist, Hypnotherapist & Expressive Arts Therapist. In-person in Gole Market, New Delhi, and online. Book on WhatsApp.";

// Section headings: left-aligned on mobile (as originally approved),
// centered with a measured max-width from tablet up.
const heading = "md:mx-auto md:max-w-[560px] md:text-center lg:max-w-[640px]";
---

<Layout title={title} description={description}>
  <!-- ===== HERO ===== -->
  <div class="relative overflow-hidden">
    <div
      class="absolute -right-[70px] -top-[90px] h-[260px] w-[260px] rounded-[58%_42%_47%_53%/55%_44%_56%_45%] bg-clay-100 md:-top-[100px] md:h-[340px] md:w-[340px] lg:-right-20 lg:-top-[120px] lg:h-[420px] lg:w-[420px]"
    >
    </div>
    <div
      class="absolute -left-20 top-[120px] h-[150px] w-[150px] rounded-[50%_50%_45%_55%/55%_50%_50%_45%] bg-sage-50 md:top-auto md:-bottom-[50px] md:-left-[70px] md:h-[180px] md:w-[180px] lg:-left-[90px] lg:-bottom-[60px] lg:h-[220px] lg:w-[220px]"
    >
    </div>

    <Header />

    <div
      class="wrap relative md:grid md:grid-cols-[1.1fr_.9fr] md:items-center md:gap-10 md:pb-[60px] md:pt-14 lg:grid-cols-[1.05fr_.95fr] lg:gap-14 lg:pb-20 lg:pt-[72px]"
    >
      <div class="pt-[22px] md:pt-0">
        <div
          class="mb-2.5 font-display text-sm font-semibold tracking-[0.01em] text-terracotta md:mb-[14px] md:text-[15px] lg:mb-4 lg:text-base"
        >
          You don't have to carry it alone.
        </div>
        <h1
          class="m-0 text-balance font-display text-[35px] font-bold leading-[1.1] tracking-[-0.02em] text-ink md:text-[46px] md:leading-[1.06] md:tracking-[-0.025em] lg:text-[60px] lg:leading-[1.04]"
        >
          Feeling anxious, low, or stretched thin?
        </h1>
        <p class="mt-4 text-[16.5px] leading-[1.55] text-ink-soft md:mt-5 md:max-w-[420px] md:text-[18px] lg:mt-6 lg:max-w-[480px] lg:text-[19px]">
          Gentle, professional therapy for anxiety, stress &amp; relationships &mdash; in central
          Delhi &amp; online, at your pace.
        </p>

        <div class="mt-7 hidden gap-3 md:flex lg:mt-8 lg:gap-3.5">
          <WhatsAppCTA size="lg">Book on WhatsApp</WhatsAppCTA>
          <CallCTA size="lg">Call</CallCTA>
        </div>

        <TrustStrip align="start" display="hidden lg:flex" class="mt-[34px]" />
      </div>

      <div class="relative flex justify-center pt-6 md:pt-0">
        <div class="relative">
          <div
            class="h-[300px] w-[300px] overflow-hidden rounded-[47%_53%_54%_46%/52%_45%_55%_48%] bg-clay-200 shadow-[0_24px_50px_-22px_rgba(120,70,50,0.55)] md:h-[340px] md:shadow-[0_28px_60px_-26px_rgba(120,70,50,0.55)] lg:h-[440px] lg:w-[400px] lg:shadow-[0_34px_70px_-28px_rgba(120,70,50,0.6)]"
          >
            <Image
              src={heroPhoto}
              alt={`${site.practitioner}, ${site.roles[0]}`}
              width={400}
              height={440}
              class="h-full w-full object-cover"
            />
          </div>
          <div
            class="absolute bottom-0.5 right-[30px] h-[46px] w-[46px] rounded-[50%_50%_46%_54%/55%_46%_54%_45%] bg-sage md:bottom-[10px] md:right-[20px] md:h-[54px] md:w-[54px] lg:bottom-[14px] lg:right-[26px] lg:h-[66px] lg:w-[66px]"
          >
          </div>
          <div
            class="absolute -left-1.5 top-4 h-[26px] w-[26px] rounded-[52%_48%_50%_50%] bg-clay-100 md:-left-[12px] md:top-[24px] md:h-[30px] md:w-[30px] lg:-left-[14px] lg:top-[34px] lg:h-[38px] lg:w-[38px]"
          >
          </div>
          <AvailabilityBadge
            display="hidden lg:flex"
            class="lg:absolute lg:bottom-[60px] lg:-left-[26px]"
          />
        </div>
      </div>
    </div>

    <!-- mobile+tablet: trust strip + availability sit below the photo (desktop moves them into the text column above) -->
    <div class="wrap relative pt-[22px] md:pb-[52px] lg:hidden">
      <TrustStrip />
      <div class="mt-3 flex justify-center">
        <AvailabilityBadge />
      </div>
    </div>
  </div>

  <!-- ===== IS THIS YOU ===== -->
  <Section id="concerns" innerClass="wrap pb-2 pt-11 md:pb-4 md:pt-16 lg:pt-20">
    <div class={heading}>
      <div class="font-display text-[26px] font-bold leading-[1.15] text-ink md:text-[32px] md:leading-[1.12] lg:text-[38px]">
        Does any of this feel familiar?
      </div>
      <p class="mb-[22px] mt-2 text-[15px] leading-[1.5] text-ink-soft md:mb-[34px] md:mt-2.5 md:text-base lg:mb-10 lg:mt-3 lg:text-[17px]">
        Start wherever you are &mdash; you don't need the right words to begin.
      </p>
    </div>
    <div class="grid grid-cols-2 gap-[11px] md:gap-4 lg:grid-cols-3 lg:gap-[18px]">
      {site.concerns.map((c) => <ConcernCard {...c} />)}
      <div
        class="flex flex-col justify-center rounded-[22px] bg-cream-alt p-[18px] md:rounded-[24px] md:p-6 lg:p-[26px]"
      >
        <div class="font-display text-[15px] font-semibold leading-[1.3] text-ink md:text-base lg:text-[17px]">
          Something else?
        </div>
        <div class="mt-1.5 text-[12.5px] leading-[1.4] text-ink-muted md:text-sm md:leading-[1.5]">
          Not sure where it fits? Reach out &mdash; we'll figure it out together.
        </div>
      </div>
    </div>
  </Section>

  <!-- ===== ABOUT ===== -->
  <Section
    id="about"
    background="alt"
    class="mt-[38px] md:mt-16 lg:mt-20"
    innerClass="wrap py-10 md:grid md:grid-cols-[.8fr_1.2fr] md:items-center md:gap-10 md:py-14 lg:grid-cols-[.85fr_1.15fr] lg:gap-14 lg:py-[72px]"
  >
    <div slot="decor">
      <div
        class="absolute -bottom-[50px] -left-[50px] h-[150px] w-[150px] rounded-[55%_45%_50%_50%] bg-clay-300 md:-bottom-[60px] md:-left-auto md:-right-[50px] md:h-[170px] md:w-[170px] lg:-bottom-[70px] lg:-right-[60px] lg:h-[200px] lg:w-[200px]"
      >
      </div>
    </div>

    <div class="flex items-center gap-4 md:contents">
      <div
        class="h-24 w-24 flex-none overflow-hidden rounded-[52%_48%_47%_53%/50%_52%_48%_50%] bg-clay-200 md:mx-auto md:h-[280px] md:w-[240px] md:shadow-[0_24px_50px_-24px_rgba(120,70,50,0.5)] lg:h-[340px] lg:w-[300px] lg:shadow-[0_28px_56px_-26px_rgba(120,70,50,0.5)]"
      >
        <Image
          src={aboutPhoto}
          alt={site.practitioner}
          width={300}
          height={340}
          class="h-full w-full object-cover"
        />
      </div>
      <div class="md:hidden">
        <div class="font-display text-[21px] font-bold text-ink">{site.practitioner}</div>
        <div class="mt-[3px] text-[12.5px] leading-[1.45] text-ink-softer">
          Counselling Psychologist, Hypnotherapist &amp; Expressive Arts Therapist
        </div>
      </div>
    </div>

    <div class="mt-5 md:mt-0">
      <div class="hidden font-display text-[14px] font-semibold text-terracotta md:mb-2.5 md:block lg:mb-3 lg:text-[15px]">
        About Aarushi
      </div>
      <div class="hidden font-display text-[28px] font-bold text-ink md:block lg:text-[32px]">{site.practitioner}</div>
      <div class="hidden text-[14px] text-ink-softer md:mt-[5px] md:block lg:mt-1.5 lg:text-[14.5px]">
        Counselling Psychologist, Hypnotherapist &amp; Expressive Arts Therapist
      </div>
      <p class="mt-5 text-[16.5px] leading-[1.55] text-[#5a4c40] md:mt-[18px] md:max-w-[520px] md:text-[17.5px] md:leading-[1.6] lg:mt-[22px] lg:text-[19px]">
        I offer a warm, steady place to be heard &mdash; and gentle, practical ways forward. No
        judgement, no rush. Just you, supported.
      </p>
      <p class="mt-3 text-[15px] leading-[1.55] text-ink-soft md:mt-3.5 md:max-w-[520px] md:leading-[1.6] lg:mt-4 lg:text-base">
        Over {site.experienceYears} years I've supported people through anxiety, low mood,
        relationships and life transitions &mdash; in person in Gole Market and online across
        India.
      </p>
      <a
        href="/about"
        class="mt-4 inline-block font-display text-sm font-semibold text-terracotta md:hidden"
      >
        More about my approach &rarr;
      </a>
    </div>
  </Section>

  <!-- ===== HOW IT WORKS ===== -->
  <Section id="process" innerClass="wrap pb-2 pt-11 md:pb-4 md:pt-16 lg:pt-20">
    <div class={heading}>
      <div class="font-display text-[26px] font-bold text-ink md:text-[32px] lg:text-[38px]">Getting started is easy</div>
      <p class="mb-[22px] mt-2 text-[15px] leading-[1.5] text-ink-soft md:mb-[34px] md:mt-2.5 md:text-base lg:mb-11 lg:mt-3 lg:text-[17px]">
        Three simple, unhurried steps.
      </p>
    </div>
    <div class="flex flex-col gap-3.5 md:grid md:grid-cols-3 md:gap-4 lg:gap-5">
      <StepItem
        number={1}
        title="Say hello"
        description="Message on WhatsApp or call — a short, no-pressure chat to see if we're a fit."
        radius="50% 50% 46% 54%"
      >
        <WhatsAppCTA class="mt-3 md:mt-3.5 lg:mt-4">
          <span class="md:hidden">Message on WhatsApp</span>
          <span class="hidden md:inline lg:hidden">WhatsApp</span>
          <span class="hidden lg:inline">Message on WhatsApp</span>
        </WhatsAppCTA>
      </StepItem>
      <StepItem
        number={2}
        title="First session"
        description="We talk through what's going on. Nothing is rushed — you share only what you're ready to."
        radius="48% 52% 52% 48%"
      />
      <StepItem
        number={3}
        title="A way forward"
        description="Together we shape a plan around you — in-person, online, or a mix."
        radius="52% 48% 48% 52%"
      />
    </div>
  </Section>

  <!-- ===== FEES ===== -->
  <Section
    id="fees"
    innerClass="wrap pb-2 pt-11 md:pb-4 md:pt-16 lg:grid lg:grid-cols-2 lg:items-center lg:gap-10 lg:py-20"
  >
    <div class="md:mx-auto md:max-w-[560px] md:text-center lg:mx-0 lg:max-w-none lg:text-left">
      <div class="mb-1.5 font-display text-[26px] font-bold text-ink md:mb-2 md:text-[32px] lg:mb-0 lg:text-[38px] lg:leading-[1.1]">
        Simple, transparent fees
      </div>
      <p class="mb-[18px] text-[14.5px] leading-[1.5] text-ink-soft md:mb-0 md:text-base lg:mt-3.5 lg:max-w-[400px] lg:text-[17px] lg:leading-[1.55]">
        {site.fees.intro}
      </p>
    </div>
    <div class="flex gap-3 md:mt-7 md:gap-4 lg:mt-0">
      <FeeCard label={site.fees.inPerson.label} price={site.fees.inPerson.price} note={site.fees.inPerson.note} />
      <FeeCard label={site.fees.online.label} price={site.fees.online.price} note={site.fees.online.note} />
    </div>
  </Section>

  <!-- ===== CLIENT EXPERIENCES ===== -->
  <Section background="alt" class="mt-[38px] md:mt-16 lg:mt-20" innerClass="wrap py-11 md:py-14 lg:py-[72px]">
    <div class="mb-[18px] flex items-center gap-[11px] md:mb-[30px] md:justify-center lg:mb-9">
      <span class="font-display text-[28px] font-extrabold text-ink md:text-[30px] lg:text-[34px]">★ {site.rating.value}</span>
      <span class="text-[13px] text-ink-softer md:text-sm lg:text-[15px]">from {site.rating.reviewCount} clients</span>
    </div>
    <div class="flex flex-col gap-3 md:grid md:grid-cols-2 md:gap-4 lg:grid-cols-3 lg:gap-[18px]">
      {site.testimonials.map((t) => <TestimonialCard quote={t.quote} attribution={t.attribution} />)}
    </div>
  </Section>

  <!-- ===== CLOSING CTA ===== -->
  <ClosingCta subhead="Reaching out is the hardest step. A first message can be as simple as “hi”." />
</Layout>
